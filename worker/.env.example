# Copy this file to `.env` and fill in the token. `.env` is git-ignored.
#
#   cp .env.example .env
#
# Account ID — Cloudflare dashboard → juggler.studio → Overview → right sidebar.
CLOUDFLARE_ACCOUNT_ID=498e272ba88ed63fbc24cd47ebf55072
#
# API token with the "Account Analytics → Read" permission. Used ONLY by
# stats.sh. Deliberately NOT named CLOUDFLARE_API_TOKEN: wrangler auto-loads
# .env and would treat that reserved name as its deploy credential, which this
# read-only token can't satisfy — breaking ./deploy.sh. deploy.sh uses your
# `npx wrangler login` OAuth session instead.
# Create one at: dashboard → My Profile → API Tokens → Create Token
# → "Create Custom Token" → add permission: Account · Account Analytics · Read.
CF_ANALYTICS_API_TOKEN=